    <script type="module" is:inline>
      const root = document.documentElement;
      const topbar = document.getElementById('topbar');
      let lenis = null;
      const mockup = document.getElementById('heroMockup');
      const proofScore = document.getElementById('proofScore');
      const investorForm = document.getElementById('investorForm');
      const formSuccess = document.getElementById('formSuccess');
      const spotlightCards = document.querySelectorAll('.spotlight-card');
      const revealItems = document.querySelectorAll('.reveal');
      const scoreRows = document.querySelectorAll('.score-row');

      const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

      const motionSafe = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (motionSafe) {
        import('https://esm.sh/lenis@1.3.21')
          .then(({ default: Lenis }) => {
            lenis = new Lenis({
              autoRaf: true,
              anchors: true,
              smoothWheel: true,
              syncTouch: false,
              wheelMultiplier: 0.95,
              touchMultiplier: 1,
              lerp: 0.085,
            });

            window.__flaynnLenis = lenis;
            root.classList.add('lenis-ready');
          })
          .catch(() => {
            root.classList.remove('lenis-ready');
          });
      }

      const setSpotlight = (card, x, y) => {
        card.style.setProperty('--mx', `${x}px`);
        card.style.setProperty('--my', `${y}px`);
      };

      spotlightCards.forEach((card) => {
        card.addEventListener('pointermove', (event) => {
          const rect = card.getBoundingClientRect();
          setSpotlight(card, event.clientX - rect.left, event.clientY - rect.top);
        });

        card.addEventListener('pointerleave', () => {
          setSpotlight(card, card.clientWidth / 2, card.clientHeight / 2);
        });
      });

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
          });
        },
        {
          threshold: 0.16,
          rootMargin: '0px 0px -8% 0px',
        },
      );

      revealItems.forEach((item) => revealObserver.observe(item));

      const scoreObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            scoreRows.forEach((row, index) => {
              const fill = row.querySelector('.fill');
              const value = Number(row.dataset.fill || 0);
              window.setTimeout(() => {
                fill.style.setProperty('--target', `${value}%`);
                fill.classList.add('is-ready');
              }, 120 + index * 120);
            });

            let current = 0;
            const target = 36;
            const timer = window.setInterval(() => {
              current += 1;
              if (proofScore) {
                proofScore.innerHTML = `${current}<span>/100</span>`;
              }
              if (current >= target) {
                window.clearInterval(timer);
              }
            }, 26);

            scoreObserver.disconnect();
          });
        },
        { threshold: 0.5 },
      );

      if (proofScore) scoreObserver.observe(proofScore);

      const syncTopbar = () => {
        topbar?.classList.toggle('is-scrolled', window.scrollY > 24);
      };

      window.addEventListener('scroll', syncTopbar, { passive: true });
      syncTopbar();

      if (mockup) {
        const resetMockup = () => {
          mockup.style.setProperty('--rx', '-7deg');
          mockup.style.setProperty('--ry', '10deg');
          mockup.style.setProperty('--gx', '50%');
          mockup.style.setProperty('--gy', '50%');
        };

        resetMockup();

        mockup.addEventListener('pointermove', (event) => {
          const rect = mockup.getBoundingClientRect();
          const px = (event.clientX - rect.left) / rect.width;
          const py = (event.clientY - rect.top) / rect.height;
          const ry = clamp((px - 0.5) * 18, -9, 9);
          const rx = clamp((0.5 - py) * 14 - 7, -14, 6);
          mockup.style.setProperty('--rx', `${rx}deg`);
          mockup.style.setProperty('--ry', `${ry}deg`);
          mockup.style.setProperty('--gx', `${px * 100}%`);
          mockup.style.setProperty('--gy', `${py * 100}%`);
        });

        mockup.addEventListener('pointerleave', resetMockup);
      }

      if (investorForm && formSuccess) {
        investorForm.addEventListener('submit', (event) => {
          event.preventDefault();
          if (!investorForm.reportValidity()) return;
          investorForm.hidden = true;
          formSuccess.hidden = false;
        });
      }

      document.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (event) => {
          const href = link.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (!target) return;
          event.preventDefault();
          if (lenis) {
            lenis.scrollTo(target, { offset: -12 });
            return;
          }
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    </script>
  </body>
