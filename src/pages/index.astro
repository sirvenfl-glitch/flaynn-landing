  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    
    gsap.registerPlugin(ScrollTrigger);

    // 1. Lenis Smooth Scroll
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      direction: 'vertical',
      gestureDirection: 'vertical',
      smooth: true,
      mouseMultiplier: 1,
    });
    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // 2. Spotlight Effect
    document.querySelectorAll('.bento-card').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);
      });
    });

    // 3. 3D Tilt Hero
    const tiltCard = document.querySelector('.mockup-tilt');
    const heroVisual = document.querySelector('.hero-visual');
    if (heroVisual && tiltCard) {
      heroVisual.addEventListener('mousemove', (e) => {
        const rect = heroVisual.getBoundingClientRect();
        const xRotate = 20 * (((e.clientY - rect.top) - rect.height / 2) / rect.height);
        const yRotate = -20 * (((e.clientX - rect.left) - rect.width / 2) / rect.width);
        gsap.to(tiltCard, { rotateX: xRotate, rotateY: yRotate, duration: 0.5, ease: "power2.out" });
      });
      heroVisual.addEventListener('mouseleave', () => {
        gsap.to(tiltCard, { rotateX: 10, rotateY: -15, duration: 1, ease: "elastic.out(1, 0.3)" });
      });
    }

    // 4. GSAP Animations
    // Entrée Hero
    gsap.from('.hero-copy > *', { y: 40, opacity: 0, duration: 1, stagger: 0.1, ease: "power4.out", delay: 0.2 });
    gsap.from('.mockup-tilt', {
      y: 60, opacity: 0, rotationX: 30, duration: 1.5, ease: "expo.out", delay: 0.4,
      onComplete: () => {
        document.querySelectorAll('.progress-bar').forEach(bar => {
          gsap.to(bar, { width: bar.getAttribute('data-width'), duration: 1.5, ease: "power3.out" });
        });
        gsap.to('.score-circle', { strokeDashoffset: 289 - (289 * 0.36), duration: 2, ease: "power3.out" });
      }
    });

    // Apparition globale au scroll pour toutes les autres sections
    gsap.utils.toArray('.gsap-fade-up').forEach(element => {
      gsap.from(element, {
        scrollTrigger: {
          trigger: element,
          start: 'top 85%',
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: "power3.out"
      });
    });
  </script>
