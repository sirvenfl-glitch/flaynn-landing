---
import FounderForm from '../components/FounderForm.astro';
---
<!DOCTYPE html>
<html lang="fr">
<head>
 <link rel="icon" href="/aile-favicon.png" />
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
<title>Flaynn · Votre scoring investisseur en 24h</title>
<meta name="description" content="Flaynn analyse votre dossier startup sur 5 piliers et vous livre un scoring complet en 24h. Moins de 15% des projets sont acceptés pour mise en relation investisseur." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet" />
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0A0A0F;--purple:#6B21A8;--purple-light:#9333ea;--purple-glow:rgba(107,33,168,0.35);
  --orange:#F97316;--yellow:#FACC15;--pink:#EC4899;
  --text:#F1F5F9;--text-muted:#94a3b8;--text-dim:#475569;
  --border:rgba(255,255,255,0.07);--glass:rgba(255,255,255,0.04);--glass-border:rgba(255,255,255,0.08);
  --font:'IBM Plex Sans',sans-serif;
}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden}
body{background:var(--bg);color:var(--text);font-family:var(--font);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
#canvas-bg{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0.55}
body::before{content:'';position:fixed;inset:0;z-index:1;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");opacity:0.45}
.container{max-width:1200px;margin:0 auto;padding:0 24px;position:relative;z-index:2;box-sizing:border-box}
section{position:relative;z-index:2;max-width:100%;overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 24px;height:64px;display:flex;align-items:center;transition:background .4s,border-color .4s}
nav.scrolled{background:rgba(10,10,15,.88);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1200px;margin:0 auto;width:100%;display:flex;align-items:center;justify-content:space-between}
.logo-link{display:flex;align-items:center;text-decoration:none;opacity:.95;transition:opacity .2s}
.logo-link:hover{opacity:1}
.nav-cta{display:inline-flex;align-items:center;gap:8px;background:var(--purple);color:#fff;font-family:var(--font);font-weight:600;font-size:.875rem;padding:10px 20px;border-radius:8px;text-decoration:none;border:none;cursor:pointer;transition:background .2s,transform .2s,box-shadow .2s;white-space:nowrap}
.nav-cta:hover{background:var(--purple-light);transform:translateY(-1px);box-shadow:0 8px 32px var(--purple-glow)}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding:120px 0 80px;overflow:hidden}
.hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(107,33,168,.15);border:1px solid rgba(107,33,168,.3);border-radius:100px;padding:6px 14px;font-size:.8rem;font-weight:500;color:var(--purple-light);margin-bottom:28px;letter-spacing:.02em;text-transform:uppercase}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--orange);border-radius:50%;animation:pulse-dot 2s ease-in-out infinite}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.7)}}
.hero h1{font-family:var(--font);font-size:clamp(2.4rem,4.5vw,3.8rem);font-weight:700;line-height:1.08;letter-spacing:-.03em;margin-bottom:8px}
.line-accent{background:linear-gradient(90deg,var(--purple-light) 0%,var(--pink) 50%,var(--orange) 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;display:block}
.hero-sub{font-size:1.1rem;color:var(--text-muted);max-width:480px;margin-bottom:40px;line-height:1.75;font-weight:300}
.hero-sub strong{color:var(--text);font-weight:500}
.hero-actions{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.btn-primary{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#6B21A8,#EC4899);color:#fff;font-family:var(--font);font-weight:600;font-size:1.15rem;padding:18px 48px;border-radius:100px;text-decoration:none;border:none;cursor:pointer;transition:transform .2s,box-shadow .3s;box-shadow:0 0 24px rgba(107,33,168,0.5);-webkit-appearance:none !important}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 16px 48px rgba(107,33,168,.6)}
.hero-note{font-size:.8rem;color:var(--text-dim);display:flex;align-items:center;gap:6px}

/* HERO MOCKUP */
.hero-visual{position:relative;perspective:800px}
.mockup-card{background:rgba(255,255,255,.038);border:1px solid var(--glass-border);border-radius:20px;padding:28px;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);position:relative;transform:rotateY(-8deg) rotateX(4deg);transition:transform .5s ease;box-shadow:0 40px 80px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.05),inset 0 1px 0 rgba(255,255,255,.08)}
.mockup-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;padding-bottom:18px;border-bottom:1px solid var(--border)}
.mockup-company{font-weight:700;font-size:.95rem}
.score-ring{width:52px;height:52px;position:relative}
.score-ring svg{transform:rotate(-90deg)}
.score-ring-text{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.88rem}
.mockup-pillars{display:flex;flex-direction:column;gap:11px}
.pillar-row{display:flex;align-items:center;gap:12px;font-size:.8rem}
.pillar-label{width:76px;color:var(--text-muted);font-weight:500;flex-shrink:0}
.pillar-bar{flex:1;height:5px;background:rgba(255,255,255,.07);border-radius:100px;overflow:hidden}
.pillar-fill{height:100%;border-radius:100px;transform:scaleX(0);transform-origin:left;transition:transform 1.2s cubic-bezier(.16,1,.3,1)}
.pillar-fill.animate{transform:scaleX(1)}
.pillar-score{width:30px;text-align:right;font-weight:600;font-size:.78rem}
.mockup-verdict{margin-top:18px;padding:12px 14px;background:rgba(249,115,22,.08);border:1px solid rgba(249,115,22,.22);border-radius:10px;font-size:.78rem;color:var(--orange);font-weight:500;line-height:1.55}
.mockup-glow{position:absolute;width:200px;height:200px;background:var(--purple);border-radius:50%;filter:blur(80px);opacity:.13;bottom:-80px;right:-60px;pointer-events:none}
.mockup-glow-2{position:absolute;width:120px;height:120px;background:var(--orange);border-radius:50%;filter:blur(60px);opacity:.1;top:-40px;left:-30px;pointer-events:none}

/* SECTIONS */
.section-label{font-size:.73rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--purple-light);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.section-label::before{content:'';display:block;width:24px;height:1px;background:var(--purple-light)}
.section-title{font-family:var(--font);font-size:clamp(1.8rem,3.2vw,2.7rem);font-weight:700;line-height:1.15;letter-spacing:-.02em}
.section-title .highlight{background:linear-gradient(90deg,var(--purple-light),var(--pink));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.section-sub{font-size:1rem;color:var(--text-muted);max-width:560px;margin-top:14px;line-height:1.75;font-weight:300}
.section-divider{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent)}

/* PAIN */
.pain-section{padding:100px 0}
.pain-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px}
.pain-card{background:var(--glass);border:1px solid var(--glass-border);border-radius:16px;padding:32px 26px;position:relative;overflow:hidden;transition:border-color .3s,transform .3s}
.pain-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--purple-light),transparent);opacity:0;transition:opacity .3s}
.pain-card:hover{border-color:rgba(107,33,168,.3);transform:translateY(-4px)}
.pain-card:hover::before{opacity:1}
.pain-stat{font-size:2.8rem;font-weight:700;line-height:1;margin-bottom:12px;letter-spacing:-.04em}
.pain-card:nth-child(1) .pain-stat{color:var(--orange)}
.pain-card:nth-child(2) .pain-stat{color:var(--pink)}
.pain-card:nth-child(3) .pain-stat{color:var(--yellow)}
.pain-title{font-weight:700;font-size:1rem;margin-bottom:10px}
.pain-desc{font-size:.88rem;color:var(--text-muted);line-height:1.65;font-weight:300}

/* SOLUTION */
.solution-section{padding:100px 0}
.solution-intro{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-bottom:72px}
.solution-statement{font-size:clamp(1.3rem,2.2vw,1.75rem);font-weight:700;line-height:1.45;letter-spacing:-.02em}
.solution-statement em{font-style:normal;background:linear-gradient(90deg,var(--orange),var(--yellow));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.pillars-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
.pillar-card{background:var(--glass);border:1px solid var(--glass-border);border-radius:14px;padding:22px 14px;text-align:center;transition:background .3s,border-color .3s,transform .3s}
.pillar-card:hover{background:rgba(107,33,168,.12);border-color:rgba(107,33,168,.35);transform:translateY(-6px)}
.pillar-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:1.25rem}
.pillar-card-title{font-weight:700;font-size:.8rem;letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px}
.pillar-card-desc{font-size:.72rem;color:var(--text-dim);line-height:1.5}

/* HOW */
.how-section{padding:100px 0}
.steps-row{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:56px;position:relative}
.steps-row::before{content:'';position:absolute;top:36px;left:calc(100%/6);right:calc(100%/6);height:1px;background:linear-gradient(90deg,var(--purple-light),var(--pink),var(--orange));z-index:0}
.step-card{background:var(--glass);border:1px solid var(--glass-border);border-radius:16px;padding:30px 22px;position:relative;z-index:1;transition:transform .3s,border-color .3s}
.step-card:hover{transform:translateY(-4px);border-color:rgba(107,33,168,.3)}
.step-num{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;margin-bottom:18px}
.step-card:nth-child(1) .step-num{background:rgba(107,33,168,.2);color:var(--purple-light);border:1px solid rgba(107,33,168,.4)}
.step-card:nth-child(2) .step-num{background:rgba(236,72,153,.15);color:var(--pink);border:1px solid rgba(236,72,153,.3)}
.step-card:nth-child(3) .step-num{background:rgba(249,115,22,.15);color:var(--orange);border:1px solid rgba(249,115,22,.3)}
.step-title{font-weight:700;font-size:1rem;margin-bottom:10px}
.step-desc{font-size:.88rem;color:var(--text-muted);line-height:1.65;font-weight:300}
.step-tag{margin-top:14px;display:inline-block;font-size:.7rem;font-weight:600;padding:4px 10px;border-radius:100px;letter-spacing:.05em;text-transform:uppercase}
.step-card:nth-child(1) .step-tag{background:rgba(107,33,168,.15);color:var(--purple-light)}
.step-card:nth-child(2) .step-tag{background:rgba(236,72,153,.1);color:var(--pink)}
.step-card:nth-child(3) .step-tag{background:rgba(249,115,22,.1);color:var(--orange)}

/* COMPARE */
.compare-section{padding:100px 0}
.compare-table{margin-top:56px;border:1px solid var(--glass-border);border-radius:20px;overflow:hidden}
.compare-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;align-items:center}
.compare-row.header-row{background:rgba(107,33,168,.08);border-bottom:1px solid var(--border)}
.compare-cell{padding:16px 22px;font-size:.88rem;border-right:1px solid var(--border)}
.compare-cell:last-child{border-right:none}
.compare-row:not(.header-row){border-bottom:1px solid rgba(255,255,255,.04)}
.compare-row:last-child{border-bottom:none}
.compare-row:not(.header-row):hover{background:rgba(255,255,255,.02)}
.compare-header-cell{padding:18px 22px;font-weight:700;font-size:.82rem;border-right:1px solid var(--border)}
.compare-header-cell:last-child{border-right:none}
.flaynn-col{color:var(--purple-light)}
.check{color:var(--yellow)}.cross{color:var(--text-dim)}.partial{color:var(--orange);font-size:.82rem}
.feature-name{color:var(--text-muted);font-weight:400}

/* PROOF */
.proof-section{padding:100px 0}
.proof-inner{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.score-showcase{background:var(--glass);border:1px solid var(--glass-border);border-radius:20px;padding:40px;text-align:center;position:relative;overflow:hidden}
.score-showcase::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(107,33,168,.14) 0%,transparent 70%);pointer-events:none}
.big-score{font-size:5.5rem;font-weight:700;letter-spacing:-.05em;line-height:1;background:linear-gradient(135deg,var(--orange) 0%,var(--pink) 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:8px}
.big-score-label{font-size:.85rem;color:var(--text-muted);margin-bottom:28px}
.score-breakdown{display:grid;grid-template-columns:1fr 1fr;gap:10px;text-align:left}
.score-item{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:10px;padding:12px 14px}
.score-item-label{font-size:.7rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px}
.score-item-val{font-size:1.2rem;font-weight:700}
.proof-quote{font-size:clamp(1.2rem,2vw,1.6rem);font-weight:700;line-height:1.45;letter-spacing:-.02em;margin-bottom:20px}
.proof-quote em{font-style:normal;color:var(--orange)}
.proof-body{font-size:.95rem;color:var(--text-muted);line-height:1.8;font-weight:300;margin-bottom:28px}
.proof-body strong{color:var(--text);font-weight:500}
.beta-badge{display:inline-flex;align-items:center;gap:12px;background:rgba(250,204,21,.07);border:1px solid rgba(250,204,21,.22);border-radius:12px;padding:16px 18px}
.beta-text strong{display:block;font-weight:700;color:var(--yellow);font-size:.92rem;margin-bottom:2px}
.beta-text span{font-size:.78rem;color:var(--text-muted)}
.spots-counter{display:flex;gap:5px;margin-top:12px;flex-wrap:wrap}
.spot-dot{width:26px;height:7px;border-radius:100px;background:rgba(250,204,21,.2);border:1px solid rgba(250,204,21,.28)}
.spot-dot.taken{background:var(--yellow)}

/* INVESTORS */
.investors-section{padding:100px 0;position:relative}
.investors-section::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 0%,rgba(107,33,168,.04) 50%,transparent 100%);pointer-events:none}
.investors-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;position:relative;z-index:1}
.investor-benefits{display:flex;flex-direction:column;gap:14px;margin-top:28px}
.benefit-row{display:flex;align-items:flex-start;gap:14px;padding:14px 16px;background:var(--glass);border:1px solid var(--glass-border);border-radius:12px;transition:border-color .3s,transform .3s}
.benefit-row:hover{border-color:rgba(107,33,168,.3);transform:translateX(4px)}
.benefit-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem}
.benefit-text strong{display:block;font-weight:600;font-size:.88rem;margin-bottom:2px}
.benefit-text span{font-size:.8rem;color:var(--text-muted);line-height:1.5}
.investor-form-area{background:var(--glass);border:1px solid var(--glass-border);border-radius:20px;padding:36px;position:relative;overflow:hidden}
.investor-form-area::before{content:'';position:absolute;top:0;right:0;width:160px;height:160px;background:radial-gradient(circle,rgba(249,115,22,.1) 0%,transparent 70%);pointer-events:none}
.form-title{font-weight:700;font-size:1.2rem;margin-bottom:6px}
.form-sub{font-size:.82rem;color:var(--text-muted);margin-bottom:24px;line-height:1.6}
.form-field{margin-bottom:14px}
.form-field label{display:block;font-size:.78rem;font-weight:500;color:var(--text-muted);margin-bottom:7px;letter-spacing:.02em}
.form-field input,.form-field select{width:100%;background:rgba(255,255,255,.05);border:1px solid var(--glass-border);border-radius:8px;padding:11px 13px;color:var(--text);font-family:var(--font);font-size:.88rem;transition:border-color .2s,background .2s;outline:none;-webkit-appearance:none;appearance:none}
.form-field input::placeholder{color:var(--text-dim)}
.form-field input:focus,.form-field select:focus{border-color:var(--purple-light);background:rgba(107,33,168,.08)}
.form-field select option{background:#1a1a2e;color:var(--text)}
.btn-investor{width:100%;padding:13px;background:linear-gradient(135deg,var(--orange),#e85d04);color:#fff;font-family:var(--font);font-weight:600;font-size:.92rem;border:none;border-radius:10px;cursor:pointer;transition:transform .2s,box-shadow .3s;margin-top:6px}
.btn-investor:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(249,115,22,.4)}
.form-disclaimer{font-size:.7rem;color:var(--text-dim);text-align:center;margin-top:10px;line-height:1.5}
.form-success{display:none;text-align:center;padding:32px 20px}
.form-success.show{display:block}

/* CTA */
.cta-section{padding:120px 0;text-align:center}
.cta-glow{position:absolute;width:600px;height:400px;background:radial-gradient(ellipse,rgba(107,33,168,.18) 0%,transparent 70%);left:50%;top:50%;transform:translate(-50%,-50%);pointer-events:none}
.cta-title{font-size:clamp(1.9rem,3.8vw,3.1rem);font-weight:700;letter-spacing:-.03em;line-height:1.1;max-width:680px;margin:0 auto 18px}
.cta-sub{font-size:1rem;color:var(--text-muted);max-width:460px;margin:0 auto 36px;line-height:1.75;font-weight:300}
.cta-actions{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap}
.btn-large{display:inline-flex;align-items:center;gap:10px;padding:17px 32px;font-size:1rem;font-weight:700;border-radius:12px}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;padding:17px 26px;background:transparent;color:var(--text-muted);font-family:var(--font);font-weight:500;font-size:.92rem;border:1px solid var(--border);border-radius:12px;text-decoration:none;transition:color .2s,border-color .2s}
.btn-ghost:hover{color:var(--text);border-color:var(--glass-border)}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:48px 0 32px;position:relative;z-index:2}
.footer-inner{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:32px;margin-bottom:36px}
.footer-brand p{font-size:.82rem;color:var(--text-dim);margin-top:8px;max-width:240px;line-height:1.65}
.footer-links{display:flex;flex-direction:column;gap:10px}
.footer-links h4{font-weight:700;font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-bottom:2px}
.footer-links a,.ff-footer-link{font-size:.82rem;color:var(--text-dim);text-decoration:none;transition:color .2s}
.footer-links a:hover,.ff-footer-link:hover{color:var(--text)}
.ff-footer-link{background:none;border:none;cursor:pointer;padding:0;font-family:var(--font);text-align:left}
.footer-social{display:flex;gap:10px;margin-top:14px}
.social-link{width:34px;height:34px;background:var(--glass);border:1px solid var(--glass-border);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);text-decoration:none;transition:background .2s,border-color .2s,color .2s}
.social-link:hover{background:rgba(107,33,168,.15);border-color:rgba(107,33,168,.3);color:var(--text)}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;padding-top:22px;border-top:1px solid rgba(255,255,255,.04);font-size:.78rem;color:var(--text-dim);flex-wrap:wrap;gap:12px}
.footer-legal{display:flex;gap:18px}
.footer-legal a{color:var(--text-dim);text-decoration:none;transition:color .2s}
.footer-legal a:hover{color:var(--text-muted)}

/* ANIMATIONS */
.fade-up{opacity:0;transform:translateY(36px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.fade-up.visible{opacity:1;transform:translateY(0)}
.fade-up-delay-1{transition-delay:.1s}.fade-up-delay-2{transition-delay:.2s}.fade-up-delay-3{transition-delay:.3s}.fade-up-delay-4{transition-delay:.4s}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}

/* RESPONSIVE */
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;gap:48px}
  .hero-visual{max-width:460px;margin:0 auto}
  .mockup-card{transform:none}
  .pain-grid{grid-template-columns:1fr}
  .pillars-grid{grid-template-columns:repeat(3,1fr)}
  .solution-intro{grid-template-columns:1fr;gap:40px}
  .steps-row{grid-template-columns:1fr}
  .steps-row::before{display:none}
  .compare-row{grid-template-columns:2fr 1fr 1fr}
  .compare-header-cell:nth-child(4),.compare-cell:nth-child(4){display:none}
  .proof-inner{grid-template-columns:1fr}
  .investors-inner{grid-template-columns:1fr}
  .footer-inner{flex-direction:column}
  .hero h1{font-size:2.2rem}
  .hero-sub{font-size:1rem}
  .hero-actions{flex-direction:column;align-items:stretch}
  .hero-actions .btn-primary{justify-content:center;text-align:center}
  .hero-actions .hero-note{justify-content:center}
  .solution-statement{font-size:1.15rem}
  .proof-quote{font-size:1.2rem}
  .cta-title{font-size:1.9rem}
}
@media(max-width:600px){
  .container{padding:0 16px}
  .hero{min-height:auto;padding:100px 0 60px}
  .hero h1{font-size:1.8rem;letter-spacing:-.02em}
  .hero-sub{font-size:.92rem;margin-bottom:28px}
  .hero-badge{font-size:.7rem;padding:5px 12px}
  .section-title{font-size:1.5rem}
  .pain-stat{font-size:2.2rem}
  .pain-card{padding:24px 20px}
  .big-score{font-size:3.8rem}
  .big-score-label{font-size:.75rem}
  .score-breakdown{grid-template-columns:1fr}
  .score-item{padding:10px 12px}
  .proof-quote{font-size:1.05rem}
  .proof-body{font-size:.88rem}
  .beta-badge{flex-direction:column;align-items:flex-start;gap:8px;padding:14px 16px}
  .investors-inner{gap:40px}
  .investor-form-area{padding:24px 20px}
  .form-title{font-size:1.05rem}
  .cta-title{font-size:1.6rem}
  .cta-sub{font-size:.88rem}
  .btn-large{padding:15px 24px;font-size:.92rem;justify-content:center}
  .btn-ghost{padding:14px 20px;font-size:.85rem}
  .compare-table{border-radius:14px}
  .mockup-card{padding:20px;border-radius:14px}
  .mockup-verdict{font-size:.72rem;padding:10px 12px}
  .footer-inner{gap:24px}
  .footer-bottom{flex-direction:column;align-items:flex-start;gap:8px}
  .footer-legal{flex-wrap:wrap;gap:12px}
  .pillars-grid{grid-template-columns:1fr 1fr}
  .pillar-card:last-child{grid-column:1/-1}
  .compare-row{grid-template-columns:1.5fr 1fr 1fr}
  .compare-cell,.compare-header-cell{padding:12px 10px;font-size:.78rem}
  .cta-actions{flex-direction:column;align-items:stretch}
}
@media(max-width:380px){
  .hero h1{font-size:1.55rem}
  .section-title{font-size:1.3rem}
  .pain-stat{font-size:1.9rem}
  .btn-primary{padding:13px 20px;font-size:.88rem}
  .big-score{font-size:3rem}
  .cta-title{font-size:1.35rem}
  .nav-cta{font-size:.78rem;padding:8px 14px}
}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:rgba(107,33,168,.4);border-radius:100px}
::-webkit-scrollbar-thumb:hover{background:var(--purple-light)}
</style>
</head>
