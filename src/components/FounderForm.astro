  --glass-border:rgba(255,255,255,0.08);
  --bg:#0A0A0F;
  --font:'IBM Plex Sans',sans-serif;
  position:fixed;
  inset:0;
  z-index:9000;
  width:100%;
  height:100%;
  background:
    radial-gradient(circle at 18% 18%, rgba(107,33,168,.22), transparent 32%),
    radial-gradient(circle at 82% 78%, rgba(236,72,153,.08), transparent 28%),
    var(--bg);
  font-family:var(--font);
  color:var(--text);
  display:flex;
  flex-direction:column;
  overflow-y:auto;
  -webkit-font-smoothing:antialiased;
}

#ff-overlay[hidden]{display:none}

/* header */
.ff-header{
  position:fixed;
  top:0;
  left:0;
  right:0;
  z-index:9001;
  pointer-events:none;
}

.ff-progress-track{
  height:2px;
  background:rgba(255,255,255,.05);
  position:relative;
}

.ff-bar{
  height:100%;
  background:linear-gradient(90deg,var(--purple-light),var(--pink),var(--orange));
  width:0%;
  transition:width .3s ease-out;
}

.ff-header-meta{
  position:absolute;
  inline-size:1px;
  block-size:1px;
  overflow:hidden;
  clip-path:inset(50%);
  white-space:nowrap;
}

/* close */
.ff-close{
  position:fixed;
  top:18px;
  right:18px;
  z-index:9010;
  width:40px;
  height:40px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:var(--glass);
  border:1px solid var(--glass-border);
  border-radius:10px;
  color:var(--text-muted);
  cursor:pointer;
  transition:background .2s,border-color .2s,color .2s,transform .2s;
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
}

.ff-close:hover{
  background:rgba(107,33,168,.12);
  border-color:rgba(107,33,168,.35);
  color:var(--text);
  transform:translateY(-1px);
}

/* layout */
.ff-main{
  flex:1;
