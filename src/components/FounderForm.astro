  letter-spacing:0;
  text-transform:none;
}

/* ─── Bouton fermer ───────────────────────────────────────── */
.ff-close{
  position:fixed;
  top:16px;
  right:20px;
  z-index:9010;
  width:32px;height:32px;
  background:transparent;
  border:1px solid rgba(255,255,255,.1);
  border-radius:50%;
  color:var(--text-dim);
