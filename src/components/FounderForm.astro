<style>
#ff-overlay *,#ff-overlay *::before,#ff-overlay *::after{box-sizing:border-box;margin:0;padding:0}

#ff-overlay{
  --ok:#4ade80;
  --err:#f87171;
  --gold:#C9A84C;
  --purple-light:#9333ea;
  --pink:#EC4899;
  --purple:#6B21A8;
  --orange:#F97316;
  --text:#F1F5F9;
  --text-muted:#94a3b8;
  --text-dim:#475569;
  --bg:#0A0A0F;
  --font:'IBM Plex Sans',sans-serif;
  position:fixed;
  inset:0;
  z-index:9000;
  width:100%;
  height:100%;
  background:
    radial-gradient(ellipse at 32% 35%, rgba(107,33,168,.14), transparent 58%),
    var(--bg);
  font-family:var(--font);
  color:var(--text);
  display:flex;
  flex-direction:column;
  overflow-y:auto;
}

#ff-overlay[hidden]{display:none}

/* ───────── Header ───────── */
.ff-header{
  position:fixed;
  top:0;
  left:0;
  right:0;
  z-index:9001;
}

.ff-progress-track{
  height:2px;
  background:rgba(255,255,255,.06);
  position:relative;
}

.ff-bar{
  height:100%;
  background:linear-gradient(90deg,var(--purple-light),var(--pink));
  width:0%;
  transition:width .3s ease-out;
}

/* on garde ces éléments dans le DOM pour ne pas casser le JS,
   mais on les masque visuellement */
.ff-header-meta,
.ff-close{
  display:none !important;
}

/* ───────── Main / Steps ───────── */
.ff-main{
  flex:1;
  min-height:100dvh;
  display:flex;
  align-items:flex-start;
  justify-content:center;
  padding:88px 32px 56px;
  width:100%;
}

.ff-step{
  position:relative;
  width:100%;
  max-width:720px;
  margin:0 auto;
  animation:ff-in .3s ease-out both;
}

.ff-step[hidden]{display:none!important}

.ff-step.leaving{
  animation:ff-out .22s ease-in both;
  pointer-events:none;
}

/* supprime le gros numéro décoratif */
.ff-step::before{
  display:none;
}

.ff-step-inner{
  position:relative;
  z-index:1;
  width:min(100%,680px);
  margin:0 auto;
  padding-top:12px;
}

@keyframes ff-in{
  from{opacity:0;transform:translateY(32px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes ff-out{
  from{opacity:1;transform:translateY(0)}
  to{opacity:0;transform:translateY(-18px)}
}

/* ───────── Typo ───────── */
.ff-eyebrow{
  font-size:.72rem;
