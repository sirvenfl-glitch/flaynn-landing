}
.ff-btn-back:hover{color:var(--text-muted)}

/* ─── Keyboard hint ───────────────────────────────────────── */
.ff-kbd-bar{
  margin-top:14px;
  font-size:.72rem;
  color:var(--text-dim);
  display:flex;align-items:center;justify-content:flex-end;gap:8px;
