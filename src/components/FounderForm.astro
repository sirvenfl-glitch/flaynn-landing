.ff-btn-back{background:transparent;border:1px solid var(--border);color:var(--text-muted);font-family:var(--font);font-weight:500;font-size:.9rem;padding:11px 20px;border-radius:10px;cursor:pointer;transition:color .2s,border-color .2s}
