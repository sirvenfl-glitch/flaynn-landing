<script define:vars={{ BETA_CODE, WEBHOOK_URL, UPLOAD_URL }}>
(function(){
  const TOTAL_STEPS = 29; // steps 1-29 (step 0 = code accès)

  // ── State ──────────────────────────────────────────────────
  let currentStep = 0;
  let startTime = null;
  const csrfToken = crypto.randomUUID();
  const uploadedFiles = { 27: { url: '', filename: '' }, 29: { url: '', filename: '' } };
  const SESSION_KEY = 'ff_data';

  // ── Elements ───────────────────────────────────────────────
  const overlay = document.getElementById('ff-overlay');
  const closeBtn = document.getElementById('ff-close');
  const progressBar = document.getElementById('ff-bar');
  const stepLabel = document.getElementById('ff-step-label');

  // ── Helpers ────────────────────────────────────────────────
  function getStep(n){ return document.querySelector(`.ff-step[data-step="${n}"]`); }
  function getInput(n){ return document.getElementById(`ff-${n}`); }
  function getError(n){ return document.getElementById(`ff-err-${n}`); }
  function setError(n, msg){ const e = getError(n); if(e) e.textContent = msg; }
  function clearError(n){ const e = getError(n); if(e) e.textContent = ''; }

  function saveSession(){
    const data = {};
    for(let i = 1; i <= 29; i++){
      const el = getInput(i);
      if(!el) continue;
      if(el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') data[`ff-${i}`] = el.value;
    }
    // choices
    document.querySelectorAll('.ff-choice.selected').forEach(btn => {
      const group = btn.closest('.ff-choices');
      if(group) data[`choice-${group.id}`] = btn.dataset.value;
    });
    sessionStorage.setItem(SESSION_KEY, JSON.stringify(data));
  }

  function loadSession(){
    try{
      const raw = sessionStorage.getItem(SESSION_KEY);
      if(!raw) return;
      const data = JSON.parse(raw);
      for(const [k, v] of Object.entries(data)){
        if(k.startsWith('ff-')){
          const el = document.getElementById(k);
          if(el && el.tagName !== 'INPUT' || el && el.type !== 'file') el.value = v;
        } else if(k.startsWith('choice-')){
          const group = document.getElementById(k.replace('choice-',''));
          if(group){
            group.querySelectorAll('.ff-choice').forEach(btn => {
              if(btn.dataset.value === v) btn.classList.add('selected');
            });
          }
        }
      }
      updateCounters();
    } catch(e){}
  }

  function updateCounters(){
    [[7,140],[8,400],[9,400],[20,500]].forEach(([n,max]) => {
      const el = getInput(n);
      const counter = document.getElementById(`ff-count-${n}`);
      if(el && counter) counter.textContent = `${el.value.length} / ${max}`;
    });
  }

  function updateProgress(step){
    const pct = step === 0 ? 0 : Math.round((step / TOTAL_STEPS) * 100);
    progressBar.style.width = pct + '%';
    stepLabel.textContent = step === 0 ? 'Code d\'accès' : `Étape ${step} / ${TOTAL_STEPS}`;
  }

  function updateRequiredLabels(){
    const revenus = getChoiceValue(17);
    const req = revenus === 'Oui';
    ['18','19'].forEach(n => {
      const label = document.getElementById(`ff-${n}-req-label`);
      if(label) label.innerHTML = req ? '<span class="ff-req">*</span>' : '<span class="ff-opt">(Optionnel)</span>';
    });
  }

  function getChoiceValue(step){
    const group = document.getElementById(`ff-${step}`);
    if(!group) return '';
    const sel = group.querySelector('.ff-choice.selected');
    return sel ? sel.dataset.value : '';
  }

  // ── Validation ────────────────────────────────────────────
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  const URL_RE = /^https?:\/\/.+\..+/;

  function validate(step){
    clearError(step);
    const el = getInput(step);

    switch(step){
      case 0:{
        const val = el ? el.value.trim() : '';
        if(val !== BETA_CODE){ setError(0,'Code invalide. Contactez contact@flaynn.fr'); return false; }
        return true;
      }
      case 1: case 3: case 4: case 6: case 10: case 11: case 13: case 22: case 24: case 26:{
        if(!el || !el.value.trim()){ setError(step,'Ce champ est requis.'); return false; }
        return true;
      }
      case 2:{
        if(!el || !el.value.trim()){ setError(2,'Ce champ est requis.'); return false; }
        if(!EMAIL_RE.test(el.value.trim())){ setError(2,'Adresse email invalide.'); return false; }
        return true;
      }
      case 7:{
        if(!el || !el.value.trim()){ setError(7,'Ce champ est requis.'); return false; }
        return true;
      }
      case 8: case 9:{
        if(!el || !el.value.trim()){ setError(step,'Ce champ est requis.'); return false; }
        return true;
      }
      case 12:{
        if(!el || el.value === ''){ setError(12,'Ce champ est requis.'); return false; }
        return true;
      }
      case 16: case 17: case 21: case 23:{
        if(!getChoiceValue(step)){ setError(step,'Veuillez sélectionner une option.'); return false; }
        return true;
      }
      case 18: case 19:{
        const revenus = getChoiceValue(17);
        if(revenus === 'Oui' && (!el || el.value === '')){ setError(step,'Ce champ est requis.'); return false; }
        return true;
      }
      case 20:{
        if(!el || !el.value.trim()){ setError(20,'Ce champ est requis.'); return false; }
        return true;
      }
      case 27:{
        if(!uploadedFiles[27].url){ setError(27,'Veuillez uploader votre pitch deck.'); return false; }
        return true;
      }
      case 28:{
        const val = el ? el.value.trim() : '';
        if(val && !URL_RE.test(val)){ setError(28,'URL invalide (commencer par https://).'); return false; }
        return true;
      }
      // optionals: 5, 14, 15, 25, 29
      default: return true;
    }
  }

  // ── Navigation ────────────────────────────────────────────
  function showStep(n, direction = 1){
    const prev = getStep(currentStep);
    const next = getStep(n);
    if(!next) return;

    if(prev && !prev.hidden){
      prev.classList.add('leaving');
      setTimeout(() => { prev.hidden = true; prev.classList.remove('leaving'); }, 250);
    }

    setTimeout(() => {
      next.hidden = false;
      currentStep = n;
      updateProgress(n);
      updateRequiredLabels();
      window.scrollTo(0,0);

      // focus first input
      const firstInput = next.querySelector('input:not([type=file]),textarea,.ff-choice');
      if(firstInput) firstInput.focus();

      saveSession();
    }, direction === -1 ? 0 : 50);
  }

  function nextStep(step){
    if(!validate(step)) return;
    if(step === 29){ submitForm(); return; }
    showStep(step + 1, 1);
  }

  function prevStep(step){
    if(step <= 1){ showStep(0, -1); return; }
    showStep(step - 1, -1);
  }

  // ── Open / Close ──────────────────────────────────────────
  function openForm(){
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    startTime = Date.now();
    currentStep = 0;
    updateProgress(0);
    // show step 0
    document.querySelectorAll('.ff-step').forEach((s,i) => { s.hidden = i !== 0; });
    const inp = getInput(0);
    if(inp) inp.focus();
    loadSession();
  }

  function closeForm(){
    overlay.hidden = true;
    document.body.style.overflow = '';
  }

  // expose globally so any CTA on the page can trigger the form
  window.openFounderForm = openForm;
  closeBtn.addEventListener('click', closeForm);
  overlay.addEventListener('click', e => { if(e.target === overlay) closeForm(); });

  document.addEventListener('keydown', e => {
    if(e.key === 'Escape' && !overlay.hidden) closeForm();
  });

  // ── Button delegation ─────────────────────────────────────
  overlay.addEventListener('click', e => {
    const next = e.target.closest('.ff-btn-next');
    const back = e.target.closest('.ff-btn-back');
    if(next){ nextStep(parseInt(next.dataset.step)); return; }
    if(back){ prevStep(parseInt(back.dataset.step)); return; }
  });

  // Enter key on inputs
  overlay.addEventListener('keydown', e => {
    if(e.key !== 'Enter') return;
    const el = e.target;
    if(el.tagName === 'TEXTAREA') return; // allow newlines in textarea
    const step = getStep(currentStep);
    if(!step) return;
    const nextBtn = step.querySelector('.ff-btn-next');
    if(nextBtn) nextBtn.click();
  });

  // ── Choice buttons ────────────────────────────────────────
  overlay.addEventListener('click', e => {
    const choice = e.target.closest('.ff-choice');
    if(!choice) return;
    const group = choice.closest('.ff-choices');
    if(!group) return;
    group.querySelectorAll('.ff-choice').forEach(b => b.classList.remove('selected'));
    choice.classList.add('selected');
    choice.setAttribute('aria-pressed','true');
    clearError(currentStep);
    saveSession();
  });

  // ── Counters ──────────────────────────────────────────────
  [[7,140],[8,400],[9,400],[20,500]].forEach(([n,max]) => {
    const el = getInput(n);
    const counter = document.getElementById(`ff-count-${n}`);
    if(el && counter){
      el.addEventListener('input', () => { counter.textContent = `${el.value.length} / ${max}`; saveSession(); });
    }
  });

  // other inputs save session
  for(let i = 1; i <= 29; i++){
    const el = getInput(i);
    if(el && el.type !== 'file'){
      el.addEventListener('input', () => saveSession());
    }
  }

  // ── File upload ───────────────────────────────────────────
  function setupFileUpload(stepNum){
    const input = getInput(stepNum);
    const zone = document.getElementById(`ff-file-zone-${stepNum}`);
    const placeholder = zone ? zone.querySelector('.ff-file-placeholder') : null;
    const info = document.getElementById(`ff-file-info-${stepNum}`);
    const nameEl = document.getElementById(`ff-file-name-${stepNum}`);
    const barEl = document.getElementById(`ff-upload-bar-${stepNum}`);
    const statusEl = document.getElementById(`ff-file-status-${stepNum}`);
    const MAX = 15 * 1024 * 1024;

    if(!input || !zone) return;

    // drag & drop
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
      e.preventDefault(); zone.classList.remove('drag-over');
      if(e.dataTransfer.files.length) uploadFile(e.dataTransfer.files[0], stepNum);
    });

    input.addEventListener('change', () => {
      if(input.files.length) uploadFile(input.files[0], stepNum);
    });

    function uploadFile(file, sn){
      clearError(sn);

      // type check
      const allowed27 = ['.pdf'];
      const allowed29 = ['.pdf','.doc','.docx','.xls','.xlsx','.ppt','.pptx','.jpg','.png'];
      const allowed = sn === 27 ? allowed27 : allowed29;
      const ext = '.' + file.name.split('.').pop().toLowerCase();
      if(!allowed.includes(ext)){
        setError(sn, `Type non accepté. Formats : ${allowed.join(', ')}`);
        return;
      }

      if(file.size > MAX){ setError(sn,'Fichier trop volumineux (max 15 Mo).'); return; }

      // show info panel
      if(placeholder) placeholder.hidden = true;
      info.hidden = false;
      nameEl.textContent = `${file.name} (${(file.size/1024/1024).toFixed(2)} Mo)`;
      barEl.style.width = '0%';
      statusEl.textContent = 'Upload en cours…';
      statusEl.className = 'ff-file-status';

      const formData = new FormData();
      formData.append('file', file);

      const xhr = new XMLHttpRequest();
      xhr.open('POST', UPLOAD_URL);

      xhr.upload.addEventListener('progress', e => {
        if(e.lengthComputable) barEl.style.width = Math.round((e.loaded/e.total)*100) + '%';
      });

      xhr.addEventListener('load', () => {
        if(xhr.status >= 200 && xhr.status < 300){
          try{
            const res = JSON.parse(xhr.responseText);
            uploadedFiles[sn] = { url: res.url, filename: file.name };
            barEl.style.width = '100%';
            statusEl.textContent = '✓ Fichier prêt';
            statusEl.className = 'ff-file-status ok';
            clearError(sn);
          } catch(e2){
            statusEl.textContent = 'Erreur de réponse serveur.';
            statusEl.className = 'ff-file-status err';
            setError(sn,'Erreur upload. Réessayez.');
          }
        } else {
          statusEl.textContent = `Erreur ${xhr.status}`;
          statusEl.className = 'ff-file-status err';
          setError(sn,'Erreur upload. Réessayez.');
        }
      });

      xhr.addEventListener('error', () => {
        statusEl.textContent = 'Erreur réseau';
        statusEl.className = 'ff-file-status err';
        setError(sn,'Erreur réseau lors de l\'upload.');
      });

      xhr.send(formData);
    }
  }

  setupFileUpload(27);
  setupFileUpload(29);

  // ── Submit ────────────────────────────────────────────────
  async function submitForm(){
    // honeypot check
    const honeypot = document.getElementById('ff-honeypot');
    if(honeypot && honeypot.value) return; // silent block

    // timing check
    const fillDuration = Math.round((Date.now() - startTime) / 1000);
    if(fillDuration < 10) return; // silent block (bot)

    showStep(30, 1);
    const spinner = document.getElementById('ff-final-spinner');
    const success = document.getElementById('ff-final-success');
    const errorEl = document.getElementById('ff-final-error');
    spinner.hidden = false; success.hidden = true; errorEl.hidden = true;

    function v(n){ const el = getInput(n); return el ? el.value.trim() : ''; }

    const payload = {
      code_acces: v(0),
      nom_fondateur: v(1),
      email: v(2),
      pays: v(3),
      ville: v(4),
      telephone: v(5),
      nom_startup: v(6),
      pitch_une_phrase: v(7),
      probleme: v(8),
      solution: v(9),
      secteur: v(10),
      type_client: v(11),
      tam_usd: parseFloat(v(12)) || 0,
      estimation_tam: v(13),
      acquisition_clients: v(14),
      concurrents: v(15),
      stade: getChoiceValue(16),
      revenus: getChoiceValue(17),
      mrr: parseFloat(v(18)) || 0,
      clients_payants: parseInt(v(19)) || 0,
      pourquoi_vous: v(20),
      equipe_temps_plein: getChoiceValue(21),
      priorite_6_mois: v(22),
      montant_leve: getChoiceValue(23),
      jalons_18_mois: v(24),
      utilisation_fonds: v(25),
      vision_5_ans: v(26),
      pitch_deck_url: uploadedFiles[27].url,
      pitch_deck_filename: uploadedFiles[27].filename,
      lien_demo: v(28),
      doc_supplementaire_url: uploadedFiles[29].url,
      doc_supplementaire_filename: uploadedFiles[29].filename,
      submitted_at: new Date().toISOString(),
      csrf_token: csrfToken,
      fill_duration_seconds: fillDuration,
      honeypot: honeypot ? honeypot.value : ''
    };

    try{
      const res = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      spinner.hidden = true;
      if(res.ok){
        document.getElementById('ff-success-email').textContent = payload.email;
        success.hidden = false;
        sessionStorage.removeItem(SESSION_KEY);
      } else {
        errorEl.hidden = false;
      }
    } catch(e){
      spinner.hidden = true;
      errorEl.hidden = false;
    }
  }

  // retry button
  document.getElementById('ff-retry').addEventListener('click', () => {
    showStep(29, -1);
  });

  // ── Init ──────────────────────────────────────────────────
  updateProgress(0);
  updateRequiredLabels();

})();
</script>
