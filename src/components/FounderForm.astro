  transition:border-color .2s,color .2s;
}
.ff-close:hover{
  border-color:rgba(255,255,255,.25);
  color:var(--text);
}

/* ─── Écran final ─────────────────────────────────────────── */
.ff-step--final .ff-step-inner{text-align:center}
