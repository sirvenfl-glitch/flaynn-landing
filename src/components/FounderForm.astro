}
.ff-file-input{
  position:absolute;inset:0;
  opacity:0;cursor:pointer;
  width:100%;height:100%;
}
.ff-drop-idle{
  display:flex;flex-direction:column;
  align-items:center;gap:10px;
  padding:44px 24px;
  pointer-events:none;
}
.ff-drop-icon{
  width:52px;height:52px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  color:var(--text-muted);
  margin-bottom:6px;
}
.ff-drop-label{font-size:.95rem;color:var(--text-muted);font-weight:500}
.ff-drop-sub{font-size:.8rem;color:var(--text-dim)}
.ff-drop-link{color:var(--purple-light);text-decoration:underline;text-underline-offset:3px}
.ff-drop-active{padding:28px 24px}
.ff-file-row{
  display:flex;align-items:center;gap:10px;
  color:var(--text-muted);
  margin-bottom:16px;
}
.ff-file-name{font-size:.88rem;color:var(--text);font-weight:500;word-break:break-all}
.ff-upload-track{
  height:3px;
  background:rgba(255,255,255,.06);
  border-radius:100px;
  overflow:hidden;
  margin-bottom:12px;
}
.ff-upload-fill{
  height:100%;
  background:linear-gradient(90deg,var(--purple-light),var(--pink));
  width:0%;
  border-radius:100px;
  transition:width .2s;
}
.ff-file-status{font-size:.78rem;font-weight:500;color:var(--text-dim)}
.ff-file-status.ok{color:var(--ok)}
.ff-file-status.err{color:var(--err)}

/* ─── Erreur inline ───────────────────────────────────────── */
.ff-error{
  min-height:22px;
  margin-top:14px;
  font-size:.78rem;
  color:var(--err);
  display:flex;align-items:center;gap:8px;
  letter-spacing:.02em;
}
.ff-error:not(:empty)::before{
  content:'';
