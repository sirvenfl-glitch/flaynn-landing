  font-size:1.05rem;
  padding:20px 28px;
}

/* ─── Dropzone ────────────────────────────────────────────── */
.ff-dropzone{
  position:relative;
  border:1px dashed rgba(255,255,255,.12);
  border-radius:16px;
  background:transparent;
  transition:border-color .2s,background .2s;
