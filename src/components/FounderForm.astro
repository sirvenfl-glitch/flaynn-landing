}
/* selected : border purple-light + bg rgba(147,51,234,0.15) */
.ff-choice.selected{
  border-color:var(--purple-light);
  background:rgba(147,51,234,.15);
  color:var(--text);
  font-weight:600;
}
.ff-choices--duo .ff-choice{
  flex:1;
  text-align:center;
  font-size:1.05rem;
  padding:20px 28px;
}

/* ─── Dropzone ────────────────────────────────────────────── */
.ff-dropzone{
  position:relative;
  border:1px dashed rgba(255,255,255,.12);
  border-radius:16px;
  background:transparent;
  transition:border-color .2s,background .2s;
  margin-bottom:4px;
  overflow:hidden;
}
.ff-dropzone:hover,.ff-dropzone.drag-over{
  border-color:rgba(147,51,234,.4);
  background:rgba(147,51,234,.05);
}
.ff-file-input{
  position:absolute;inset:0;
  opacity:0;cursor:pointer;
  width:100%;height:100%;
}
.ff-drop-idle{
  display:flex;flex-direction:column;
  align-items:center;gap:10px;
  padding:44px 24px;
  pointer-events:none;
}
.ff-drop-icon{
  width:52px;height:52px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  color:var(--text-muted);
  margin-bottom:6px;
}
.ff-drop-label{font-size:.95rem;color:var(--text-muted);font-weight:500}
.ff-drop-sub{font-size:.8rem;color:var(--text-dim)}
.ff-drop-link{color:var(--purple-light);text-decoration:underline;text-underline-offset:3px}
.ff-drop-active{padding:28px 24px}
.ff-file-row{
  display:flex;align-items:center;gap:10px;
  color:var(--text-muted);
  margin-bottom:16px;
}
.ff-file-name{font-size:.88rem;color:var(--text);font-weight:500;word-break:break-all}
.ff-upload-track{
  height:3px;
