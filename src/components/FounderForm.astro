  --gold:#C9A84C;
  --purple:#6B21A8;
  --purple-light:#9333ea;
  --purple-glow:rgba(107,33,168,.35);
  --orange:#F97316;
  --yellow:#FACC15;
  --pink:#EC4899;
  --text:#F1F5F9;
  --text-muted:#94a3b8;
  --text-dim:#475569;
  --border:rgba(255,255,255,0.07);
