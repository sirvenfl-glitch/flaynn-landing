  ['Turquie','TR'],['Tuvalu','TV'],['Ukraine','UA'],['Uruguay','UY'],
  ['Vanuatu','VU'],['Vatican','VA'],['Venezuela','VE'],['Viêt Nam','VN'],
  ['Yémen','YE'],['Zambie','ZM'],['Zimbabwe','ZW'],
].map(([n,c])=>({label:n,value:c,prefix:flag(c)}));

// ── City data ─────────────────────────────────────────────────────────────────
const CITIES_MAP={
