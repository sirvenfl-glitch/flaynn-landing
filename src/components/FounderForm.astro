---
const BETA_CODE = import.meta.env.PUBLIC_BETA_CODE;
const WEBHOOK_URL = import.meta.env.PUBLIC_N8N_WEBHOOK_URL;
const UPLOAD_URL = import.meta.env.PUBLIC_UPLOAD_URL;
---

<!-- Overlay -->
<div id="ff-overlay" role="dialog" aria-modal="true" aria-label="Formulaire de candidature Flaynn" hidden>
  <!-- Progress bar -->
  <div class="ff-progress-wrap" aria-hidden="true">
    <div id="ff-bar" class="ff-bar"></div>
    <span id="ff-step-label" class="ff-step-label">Étape 0 / 29</span>
  </div>

  <!-- Honeypot (hidden) -->
  <input type="text" name="website" id="ff-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none!important;position:absolute;left:-9999px">

  <!-- Step container -->
  <div id="ff-steps" class="ff-steps-wrap">

    <!-- STEP 0: Beta code -->
    <div class="ff-step" data-step="0">
      <div class="ff-step-inner">
        <p class="ff-section-label">Accès restreint</p>
        <h2 class="ff-question">Code d'accès bêta</h2>
        <p class="ff-hint">Flaynn est en accès restreint. Entrez votre code pour accéder au formulaire.</p>
        <input type="text" id="ff-0" class="ff-input" placeholder="Votre code d'accès" autocomplete="off" aria-label="Code d'accès bêta" />
        <div class="ff-error" id="ff-err-0" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-next" data-step="0">Accéder →</button>
        </div>
      </div>
    </div>

    <!-- STEP 1: Nom fondateur -->
    <div class="ff-step" data-step="1" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Informations de contact</p>
        <label class="ff-question" for="ff-1">Nom complet du fondateur <span class="ff-req">*</span></label>
        <input type="text" id="ff-1" class="ff-input" autocomplete="name" aria-required="true" />
        <div class="ff-error" id="ff-err-1" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="1">← Retour</button>
          <button class="ff-btn-next" data-step="1">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 2: Email -->
    <div class="ff-step" data-step="2" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Informations de contact</p>
        <label class="ff-question" for="ff-2">Email professionnel <span class="ff-req">*</span></label>
        <input type="email" id="ff-2" class="ff-input" autocomplete="email" aria-required="true" />
        <div class="ff-error" id="ff-err-2" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="2">← Retour</button>
          <button class="ff-btn-next" data-step="2">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 3: Pays -->
    <div class="ff-step" data-step="3" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Informations de contact</p>
        <label class="ff-question" for="ff-3">Pays <span class="ff-req">*</span></label>
        <input type="text" id="ff-3" class="ff-input" autocomplete="country-name" aria-required="true" />
        <div class="ff-error" id="ff-err-3" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="3">← Retour</button>
          <button class="ff-btn-next" data-step="3">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 4: Ville -->
    <div class="ff-step" data-step="4" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Informations de contact</p>
        <label class="ff-question" for="ff-4">Ville <span class="ff-req">*</span></label>
        <input type="text" id="ff-4" class="ff-input" autocomplete="address-level2" aria-required="true" />
        <div class="ff-error" id="ff-err-4" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="4">← Retour</button>
          <button class="ff-btn-next" data-step="4">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 5: Téléphone (optionnel) -->
    <div class="ff-step" data-step="5" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Informations de contact</p>
        <label class="ff-question" for="ff-5">Numéro de téléphone <span class="ff-opt">(Optionnel)</span></label>
        <input type="tel" id="ff-5" class="ff-input" autocomplete="tel" />
        <div class="ff-error" id="ff-err-5" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="5">← Retour</button>
          <button class="ff-btn-next" data-step="5">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 6: Nom startup -->
    <div class="ff-step" data-step="6" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 1 — L'Accroche</p>
        <label class="ff-question" for="ff-6">Nom de la startup <span class="ff-req">*</span></label>
        <input type="text" id="ff-6" class="ff-input" aria-required="true" />
        <div class="ff-error" id="ff-err-6" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="6">← Retour</button>
          <button class="ff-btn-next" data-step="6">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 7: Pitch une phrase -->
    <div class="ff-step" data-step="7" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 1 — L'Accroche</p>
        <label class="ff-question" for="ff-7">En une phrase, que fait votre startup ? <span class="ff-req">*</span></label>
        <div class="ff-input-wrap">
          <input type="text" id="ff-7" class="ff-input" maxlength="140" aria-required="true" />
          <span class="ff-counter" id="ff-count-7">0 / 140</span>
        </div>
        <div class="ff-error" id="ff-err-7" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="7">← Retour</button>
          <button class="ff-btn-next" data-step="7">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 8: Problème -->
    <div class="ff-step" data-step="8" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 1 — L'Accroche</p>
        <label class="ff-question" for="ff-8">Le Problème (Point de douleur) <span class="ff-req">*</span></label>
        <div class="ff-input-wrap">
          <textarea id="ff-8" class="ff-textarea" maxlength="400" rows="4" aria-required="true"></textarea>
          <span class="ff-counter" id="ff-count-8">0 / 400</span>
        </div>
        <div class="ff-error" id="ff-err-8" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="8">← Retour</button>
          <button class="ff-btn-next" data-step="8">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 9: Solution -->
    <div class="ff-step" data-step="9" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 1 — L'Accroche</p>
        <label class="ff-question" for="ff-9">Comment résolvez-vous ce problème ? <span class="ff-req">*</span></label>
        <div class="ff-input-wrap">
          <textarea id="ff-9" class="ff-textarea" maxlength="400" rows="4" aria-required="true"></textarea>
          <span class="ff-counter" id="ff-count-9">0 / 400</span>
        </div>
        <div class="ff-error" id="ff-err-9" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="9">← Retour</button>
          <button class="ff-btn-next" data-step="9">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 10: Secteur -->
    <div class="ff-step" data-step="10" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 2 — Le Moteur</p>
        <label class="ff-question" for="ff-10">Secteur principal <span class="ff-req">*</span></label>
        <input type="text" id="ff-10" class="ff-input" placeholder="Ex : LegalTech, FinTech B2B, SaaS RH..." aria-required="true" />
        <div class="ff-error" id="ff-err-10" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="10">← Retour</button>
          <button class="ff-btn-next" data-step="10">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 11: Type client -->
    <div class="ff-step" data-step="11" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 2 — Le Moteur</p>
        <label class="ff-question" for="ff-11">Type de client cible <span class="ff-req">*</span></label>
        <input type="text" id="ff-11" class="ff-input" placeholder="Ex : PME françaises, DSI grands groupes, indépendants..." aria-required="true" />
        <div class="ff-error" id="ff-err-11" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="11">← Retour</button>
          <button class="ff-btn-next" data-step="11">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 12: TAM -->
    <div class="ff-step" data-step="12" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 2 — Le Moteur</p>
        <label class="ff-question" for="ff-12">Marché Total Adressable (TAM) en USD <span class="ff-req">*</span></label>
        <input type="number" id="ff-12" class="ff-input" placeholder="Ex : 2000000000" min="0" aria-required="true" />
        <div class="ff-error" id="ff-err-12" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="12">← Retour</button>
          <button class="ff-btn-next" data-step="12">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 13: Sources TAM -->
    <div class="ff-step" data-step="13" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 2 — Le Moteur</p>
        <label class="ff-question" for="ff-13">Comment avez-vous estimé ce chiffre ? (Sources) <span class="ff-req">*</span></label>
        <textarea id="ff-13" class="ff-textarea" rows="4" aria-required="true"></textarea>
        <div class="ff-error" id="ff-err-13" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="13">← Retour</button>
          <button class="ff-btn-next" data-step="13">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 14: Acquisition clients (optionnel) -->
    <div class="ff-step" data-step="14" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 2 — Le Moteur</p>
        <label class="ff-question" for="ff-14">Comment acquérez-vous vos clients aujourd'hui ? <span class="ff-opt">(Optionnel)</span></label>
        <textarea id="ff-14" class="ff-textarea" rows="4"></textarea>
        <div class="ff-error" id="ff-err-14" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="14">← Retour</button>
          <button class="ff-btn-next" data-step="14">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 15: Concurrents (optionnel) -->
    <div class="ff-step" data-step="15" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 2 — Le Moteur</p>
        <label class="ff-question" for="ff-15">Qui cherchez-vous à détrôner & pourquoi vous gagnez ? <span class="ff-opt">(Optionnel)</span></label>
        <textarea id="ff-15" class="ff-textarea" rows="4"></textarea>
        <div class="ff-error" id="ff-err-15" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="15">← Retour</button>
          <button class="ff-btn-next" data-step="15">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 16: Stade -->
    <div class="ff-step" data-step="16" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <p class="ff-question">À quel stade êtes-vous aujourd'hui ? <span class="ff-req">*</span></p>
        <div class="ff-choices" id="ff-16" role="group" aria-label="Stade de la startup">
          <button type="button" class="ff-choice" data-value="Idée">Idée</button>
          <button type="button" class="ff-choice" data-value="MVP">MVP</button>
          <button type="button" class="ff-choice" data-value="Pré-revenue">Pré-revenue</button>
          <button type="button" class="ff-choice" data-value="Pré-seed">Pré-seed</button>
          <button type="button" class="ff-choice" data-value="Seed">Seed</button>
          <button type="button" class="ff-choice" data-value="Série A+">Série A+</button>
        </div>
        <div class="ff-error" id="ff-err-16" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="16">← Retour</button>
          <button class="ff-btn-next" data-step="16">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 17: Revenus Oui/Non -->
    <div class="ff-step" data-step="17" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <p class="ff-question">Générez-vous des revenus ? <span class="ff-req">*</span></p>
        <div class="ff-choices ff-choices--ab" id="ff-17" role="group" aria-label="Revenus">
          <button type="button" class="ff-choice" data-value="Oui">Oui</button>
          <button type="button" class="ff-choice" data-value="Non">Non</button>
        </div>
        <div class="ff-error" id="ff-err-17" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="17">← Retour</button>
          <button class="ff-btn-next" data-step="17">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 18: MRR -->
    <div class="ff-step" data-step="18" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <label class="ff-question" for="ff-18">Revenu mensuel - MRR (en $, indiquer 0 si pré-revenu) <span id="ff-18-req-label"></span></label>
        <input type="number" id="ff-18" class="ff-input" min="0" placeholder="0" />
        <div class="ff-error" id="ff-err-18" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="18">← Retour</button>
          <button class="ff-btn-next" data-step="18">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 19: Clients payants -->
    <div class="ff-step" data-step="19" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <label class="ff-question" for="ff-19">Nombre de clients payants (indiquer 0 si aucun) <span id="ff-19-req-label"></span></label>
        <input type="number" id="ff-19" class="ff-input" min="0" placeholder="0" />
        <div class="ff-error" id="ff-err-19" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="19">← Retour</button>
          <button class="ff-btn-next" data-step="19">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 20: Pourquoi vous -->
    <div class="ff-step" data-step="20" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <label class="ff-question" for="ff-20">Pourquoi VOUS ? Présentez les fondateurs et votre avantage compétitif <span class="ff-req">*</span></label>
        <div class="ff-input-wrap">
          <textarea id="ff-20" class="ff-textarea" maxlength="500" rows="5" aria-required="true"></textarea>
          <span class="ff-counter" id="ff-count-20">0 / 500</span>
        </div>
        <div class="ff-error" id="ff-err-20" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="20">← Retour</button>
          <button class="ff-btn-next" data-step="20">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 21: Temps plein -->
    <div class="ff-step" data-step="21" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <p class="ff-question">L'équipe fondatrice est-elle à temps plein ? <span class="ff-req">*</span></p>
        <div class="ff-choices ff-choices--ab" id="ff-21" role="group" aria-label="Temps plein">
          <button type="button" class="ff-choice" data-value="Oui">Oui</button>
          <button type="button" class="ff-choice" data-value="Non">Non</button>
        </div>
        <div class="ff-error" id="ff-err-21" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="21">← Retour</button>
          <button class="ff-btn-next" data-step="21">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 22: Priorité 6 mois -->
    <div class="ff-step" data-step="22" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 3 — Exécution & Équipe</p>
        <label class="ff-question" for="ff-22">Priorité principale (6 prochains mois) <span class="ff-req">*</span></label>
        <textarea id="ff-22" class="ff-textarea" rows="4" aria-required="true"></textarea>
        <div class="ff-error" id="ff-err-22" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="22">← Retour</button>
          <button class="ff-btn-next" data-step="22">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 23: Montant levée -->
    <div class="ff-step" data-step="23" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 4 — La Demande & Projections</p>
        <p class="ff-question">Combien souhaitez-vous lever ? <span class="ff-req">*</span></p>
        <div class="ff-choices" id="ff-23" role="group" aria-label="Montant levée">
          <button type="button" class="ff-choice" data-value="< 100k€">&lt; 100k€</button>
          <button type="button" class="ff-choice" data-value="100k–500k€">100k–500k€</button>
          <button type="button" class="ff-choice" data-value="500k–1M€">500k–1M€</button>
          <button type="button" class="ff-choice" data-value="1M–3M€">1M–3M€</button>
          <button type="button" class="ff-choice" data-value="> 3M€">&gt; 3M€</button>
        </div>
        <div class="ff-error" id="ff-err-23" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="23">← Retour</button>
          <button class="ff-btn-next" data-step="23">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 24: Jalons 18 mois -->
    <div class="ff-step" data-step="24" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 4 — La Demande & Projections</p>
        <label class="ff-question" for="ff-24">Jalons clés pour les 18 prochains mois <span class="ff-req">*</span></label>
        <textarea id="ff-24" class="ff-textarea" rows="4" aria-required="true"></textarea>
        <div class="ff-error" id="ff-err-24" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="24">← Retour</button>
          <button class="ff-btn-next" data-step="24">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 25: Utilisation fonds (optionnel) -->
    <div class="ff-step" data-step="25" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 4 — La Demande & Projections</p>
        <label class="ff-question" for="ff-25">Utilisation prévue des fonds <span class="ff-opt">(Optionnel)</span></label>
        <textarea id="ff-25" class="ff-textarea" rows="4"></textarea>
        <div class="ff-error" id="ff-err-25" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="25">← Retour</button>
          <button class="ff-btn-next" data-step="25">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 26: Vision 5 ans -->
    <div class="ff-step" data-step="26" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 4 — La Demande & Projections</p>
        <label class="ff-question" for="ff-26">Si vous réussissez, à quoi ressemble votre entreprise dans 5 ans ? <span class="ff-req">*</span></label>
        <textarea id="ff-26" class="ff-textarea" rows="4" aria-required="true"></textarea>
        <div class="ff-error" id="ff-err-26" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="26">← Retour</button>
          <button class="ff-btn-next" data-step="26">Continuer →</button>
        </div>
      </div>
    </div>

    <!-- STEP 27: Pitch Deck -->
    <div class="ff-step" data-step="27" hidden>
      <div class="ff-step-inner">
        <p class="ff-section-label">Partie 5 — Documents</p>
        <label class="ff-question" for="ff-27">Pitch Deck (PDF uniquement, max 15 Mo) <span class="ff-req">*</span></label>
        <div class="ff-file-zone" id="ff-file-zone-27">
          <input type="file" id="ff-27" class="ff-file-input" accept=".pdf" aria-required="true" aria-label="Pitch Deck PDF" />
          <div class="ff-file-placeholder">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span>Cliquez ou glissez votre PDF ici</span>
            <span class="ff-file-sub">PDF uniquement · Max 15 Mo</span>
          </div>
          <div class="ff-file-info" id="ff-file-info-27" hidden>
            <div class="ff-file-name" id="ff-file-name-27"></div>
            <div class="ff-upload-bar-wrap"><div class="ff-upload-bar" id="ff-upload-bar-27"></div></div>
            <div class="ff-file-status" id="ff-file-status-27"></div>
          </div>
        </div>
        <div class="ff-error" id="ff-err-27" role="alert"></div>
        <div class="ff-nav">
          <button class="ff-btn-back" data-step="27">← Retour</button>
          <button class="ff-btn-next" data-step="27">Continuer →</button>
