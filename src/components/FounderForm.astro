    {value:'mentalhealth',label:'Santé mentale & Bien-être',prefix:'🧠'},
    {value:'edtech',label:'Edtech & Formation',prefix:'🎓'},
    {value:'elearning',label:'E-learning & Upskilling',prefix:'📚'},
    {value:'hrtech',label:'HRtech & Recrutement',prefix:'👥'},
