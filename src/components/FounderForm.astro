}
/* focus : uniquement changer la couleur du border-bottom */
.ff-input:focus,.ff-textarea:focus{
  border-bottom-color:var(--purple-light);
  background:transparent;
  box-shadow:none;
}
.ff-input::placeholder,.ff-textarea::placeholder{
  color:var(--text-dim);
