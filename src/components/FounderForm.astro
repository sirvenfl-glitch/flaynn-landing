  pointer-events:none;
}

.ff-step::before{display:none}

.ff-step-inner{
  position:relative;
  z-index:1;
  width:min(100%,760px);
  margin:0 auto;
}

@keyframes ff-in{
  from{opacity:0;transform:translateY(28px)}
