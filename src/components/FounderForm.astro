  font-family:var(--font);
  font-size:1.05rem;
  font-weight:600;
  padding:18px 52px;
  line-height:1.2;
  border:none;
  border-radius:100px;
  cursor:pointer;
  letter-spacing:.06em;
  text-transform:uppercase;
  transition:opacity .2s,transform .2s,box-shadow .2s;
  white-space:nowrap;
}
.ff-btn-primary:hover{
  opacity:.88;
  transform:translateY(-1px);
  box-shadow:0 12px 36px rgba(107,33,168,.4);
}
.ff-btn-primary:active{transform:translateY(0);box-shadow:none;opacity:1}
/* bouton Retour : texte pur, minimaliste */
.ff-btn-back{
  background:none;
