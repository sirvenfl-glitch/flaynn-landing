  color:var(--text);
  font-family:var(--font);
  font-size:1.4rem;
  font-weight:400;
  /* padding uniquement vertical */
  padding:16px 0 10px 0;
  outline:none;
  transition:border-bottom-color .2s;
  resize:none;
  -webkit-appearance:none;
