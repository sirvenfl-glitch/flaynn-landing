/* ─── Inputs — underline only, style Typeform ─────────────── */
.ff-input,.ff-textarea{
  display:block;
  width:100%;
  /* ZÉRO border-box */
  background:transparent;
  border:none;
  border-bottom:2px solid rgba(255,255,255,.15);
  border-radius:0;
