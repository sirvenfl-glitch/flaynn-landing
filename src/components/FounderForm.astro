  font-variant-numeric:tabular-nums;
  letter-spacing:.04em;
}

/* ─── Choices — cards sobres, style Blast Club ────────────── */
.ff-choices{
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  margin-bottom:8px;
}
.ff-choices--duo{gap:16px}
.ff-choice{
  background:transparent;
  border:1px solid rgba(255,255,255,.1);
  border-radius:12px;
  color:var(--text-muted);
  font-family:var(--font);
  font-size:1rem;
  font-weight:500;
  /* padding 18px 28px spec exacte */
  padding:18px 28px;
  cursor:pointer;
  transition:border-color .2s,background .2s,color .2s;
