const csCountry=document.getElementById('ff-cs-4');
const csCity=document.getElementById('ff-cs-5');
const csSector=document.getElementById('ff-cs-11');

let cbCountry=null, cbCity=null, cbSector=null;

if(csCountry) cbCountry=createCombobox(csCountry,'ff-4',COUNTRIES,"Sélectionner un pays…");
if(csSector) cbSector=createCombobox(csSector,'ff-11',SECTORS,"Rechercher un secteur…");

if(csCity){
  cbCity=createCombobox(csCity,'ff-5',[],"Sélectionnez d'abord un pays");
}

// Country → City dependency
if(cbCountry){
  const origPick=cbCountry;
  const hidden4=document.getElementById('ff-4');
  if(hidden4){
    hidden4.addEventListener('change',async()=>{
      const iso=hidden4.value;
      if(!iso||!cbCity) return;
      cbCity.reset();
      cbCity.setOptions([{value:'__loading__',label:'Chargement…',prefix:''}]);
      const cities=await loadCities(iso);
      cbCity.setOptions(cities.length?cities:[]);
      const cs5=document.getElementById('ff-cs-5');
      if(cs5){
        const trigger=cs5.querySelector('.ff-cs-trigger');
        if(trigger){
          const ph=trigger.querySelector('.ff-cs-val');
          if(ph){ph.textContent=cities.length?'Rechercher une ville…':"Aucune ville disponible";ph.classList.add('ff-cs-ph');}
        }
      }
    });
  }
}

// Session restore (called by main script's loadSession via the hidden input change event)
// Also expose globally for manual restore
window.__ffRestoreCS=function(step,val){
  if(step===4&&cbCountry){ cbCountry.setValue(val); }
  if(step===5&&cbCity){ cbCity.setValue(val); }
  if(step===11&&cbSector){ cbSector.setValue(val); }
};

