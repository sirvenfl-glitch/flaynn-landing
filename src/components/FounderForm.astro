---
const BETA_CODE = import.meta.env.PUBLIC_BETA_CODE;
const WEBHOOK_URL = import.meta.env.PUBLIC_N8N_WEBHOOK_URL;
const UPLOAD_URL = import.meta.env.PUBLIC_UPLOAD_URL;
---

<div id="ff-overlay" role="dialog" aria-modal="true" aria-label="Formulaire de candidature Flaynn" hidden>

  <input type="text" name="website" id="ff-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none!important;position:absolute;left:-9999px">

  <header class="ff-header">
    <div class="ff-progress-track" aria-hidden="true">
      <div id="ff-bar" class="ff-bar"></div>
    </div>
    <div class="ff-header-meta">
      <span class="ff-brand">Flaynn</span>
      <span id="ff-step-label" class="ff-step-label">Accès</span>
    </div>
  </header>

  <main id="ff-steps" class="ff-main">

    <div class="ff-step" data-step="0">
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Accès restreint</p>
        <h2 class="ff-q">Code d'accès bêta</h2>
        <p class="ff-hint">Flaynn est en accès restreint. Entrez votre code pour continuer.</p>
        <input type="text" id="ff-0" class="ff-input" placeholder="••••••••••" autocomplete="off" aria-label="Code d'accès bêta" />
        <div class="ff-error" id="ff-err-0" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"></div>
          <div class="ff-nav-right">
            <button class="ff-btn-next ff-btn-primary" data-step="0">Accéder</button>
          </div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="1" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Avant de commencer</p>
        <p class="ff-q">Est-ce une re-soumission&nbsp;?</p>
        <p class="ff-hint">Si vous avez déjà soumis ce dossier et souhaitez le faire re-scorer.</p>
        <div class="ff-choices ff-choices--duo" id="ff-1" role="group" aria-label="Re-soumission">
          <button type="button" class="ff-choice" data-value="Oui">Oui</button>
          <button type="button" class="ff-choice" data-value="Non">Non</button>
        </div>
        <div class="ff-error" id="ff-err-1" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="1">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="1">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="2" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Informations de contact</p>
        <label class="ff-q" for="ff-2">Nom complet du fondateur</label>
        <input type="text" id="ff-2" class="ff-input" autocomplete="name" aria-required="true" placeholder="Prénom Nom" />
        <div class="ff-error" id="ff-err-2" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="2">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="2">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="3" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Informations de contact</p>
        <label class="ff-q" for="ff-3">Email professionnel</label>
        <input type="email" id="ff-3" class="ff-input" autocomplete="email" aria-required="true" placeholder="vous@startup.com" />
        <div class="ff-error" id="ff-err-3" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="3">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="3">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="4" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Informations de contact</p>
        <label class="ff-q" for="ff-4">Pays</label>
        <input type="text" id="ff-4" class="ff-input" aria-required="true" placeholder="Ex: France" />
        <div class="ff-error" id="ff-err-4" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="4">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="4">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="5" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Informations de contact</p>
        <label class="ff-q" for="ff-5">Ville</label>
        <input type="text" id="ff-5" class="ff-input" aria-required="true" placeholder="Ex: Paris" />
        <div class="ff-error" id="ff-err-5" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="5">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="5">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="6" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Informations de contact</p>
        <label class="ff-q" for="ff-6">Numéro de téléphone <span class="ff-opt">— optionnel</span></label>
        <input type="tel" id="ff-6" class="ff-input" autocomplete="tel" placeholder="+33 6 00 00 00 00" />
        <div class="ff-error" id="ff-err-6" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="6">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="6">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="7" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">L'Accroche</p>
        <label class="ff-q" for="ff-7">Nom de la startup</label>
        <input type="text" id="ff-7" class="ff-input" aria-required="true" placeholder="Acme Inc." />
        <div class="ff-error" id="ff-err-7" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="7">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="7">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="8" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">L'Accroche</p>
        <label class="ff-q" for="ff-8">En une phrase, que fait votre startup ?</label>
        <div class="ff-field-wrap">
          <input type="text" id="ff-8" class="ff-input" maxlength="140" aria-required="true" placeholder="Nous aidons [qui] à [quoi] grâce à [comment]." />
          <span class="ff-counter" id="ff-count-8">0 / 140</span>
        </div>
        <div class="ff-error" id="ff-err-8" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="8">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="8">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="9" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">L'Accroche</p>
        <label class="ff-q" for="ff-9">Le Problème</label>
        <div class="ff-field-wrap">
          <textarea id="ff-9" class="ff-textarea" maxlength="400" rows="5" aria-required="true" placeholder="Décrivez le point de douleur de vos clients…"></textarea>
          <span class="ff-counter" id="ff-count-9">0 / 400</span>
        </div>
        <div class="ff-error" id="ff-err-9" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="9">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="9">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="10" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">L'Accroche</p>
        <label class="ff-q" for="ff-10">Comment résolvez-vous ce problème ?</label>
        <div class="ff-field-wrap">
          <textarea id="ff-10" class="ff-textarea" maxlength="400" rows="5" aria-required="true" placeholder="Votre solution en détail…"></textarea>
          <span class="ff-counter" id="ff-count-10">0 / 400</span>
        </div>
        <div class="ff-error" id="ff-err-10" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="10">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="10">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="11" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Le Moteur</p>
        <p class="ff-q">Secteur principal</p>
        <input type="hidden" id="ff-11" aria-required="true" />
        <div class="ff-cs-wrap" id="ff-cs-11" data-cs="sector"></div>
        <div class="ff-error" id="ff-err-11" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="11">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="11">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="12" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Le Moteur</p>
        <label class="ff-q" for="ff-12">Type de client cible</label>
        <input type="text" id="ff-12" class="ff-input" placeholder="PME françaises, DSI grands groupes…" aria-required="true" />
        <div class="ff-error" id="ff-err-12" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="12">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="12">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="13" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Le Moteur</p>
        <label class="ff-q" for="ff-13">Marché Total Adressable (TAM) en USD</label>
        <input type="number" id="ff-13" class="ff-input" placeholder="2 000 000 000" min="0" aria-required="true" />
        <div class="ff-error" id="ff-err-13" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="13">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="13">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="14" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Le Moteur</p>
        <label class="ff-q" for="ff-14">Comment avez-vous estimé ce chiffre ?</label>
        <textarea id="ff-14" class="ff-textarea" rows="5" aria-required="true" placeholder="Sources, méthodologie, études de marché…"></textarea>
        <div class="ff-error" id="ff-err-14" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="14">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="14">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="15" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Le Moteur</p>
        <label class="ff-q" for="ff-15">Comment acquérez-vous vos clients ? <span class="ff-opt">— optionnel</span></label>
        <textarea id="ff-15" class="ff-textarea" rows="5" placeholder="Canaux, stratégie, coût d'acquisition…"></textarea>
        <div class="ff-error" id="ff-err-15" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="15">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="15">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="16" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Le Moteur</p>
        <label class="ff-q" for="ff-16">Qui cherchez-vous à détrôner ? <span class="ff-opt">— optionnel</span></label>
        <textarea id="ff-16" class="ff-textarea" rows="5" placeholder="Concurrents directs et votre avantage différentiel…"></textarea>
        <div class="ff-error" id="ff-err-16" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="16">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="16">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="17" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <p class="ff-q">À quel stade êtes-vous aujourd'hui ?</p>
        <div class="ff-choices" id="ff-17" role="group" aria-label="Stade">
          <button type="button" class="ff-choice" data-value="Idée">Idée</button>
          <button type="button" class="ff-choice" data-value="MVP">MVP</button>
          <button type="button" class="ff-choice" data-value="Pré-revenue">Pré-revenue</button>
          <button type="button" class="ff-choice" data-value="Pré-seed">Pré-seed</button>
          <button type="button" class="ff-choice" data-value="Seed">Seed</button>
          <button type="button" class="ff-choice" data-value="Série A+">Série A+</button>
        </div>
        <div class="ff-error" id="ff-err-17" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="17">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="17">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="18" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <p class="ff-q">Générez-vous des revenus ?</p>
        <div class="ff-choices ff-choices--duo" id="ff-18" role="group" aria-label="Revenus">
          <button type="button" class="ff-choice" data-value="Oui">Oui</button>
          <button type="button" class="ff-choice" data-value="Non">Non</button>
        </div>
        <div class="ff-error" id="ff-err-18" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="18">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="18">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="19" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <label class="ff-q" for="ff-19">Revenu mensuel — MRR en $ <span id="ff-19-req-label"></span></label>
        <input type="number" id="ff-19" class="ff-input" min="0" placeholder="0" />
        <div class="ff-error" id="ff-err-19" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="19">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="19">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="20" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <label class="ff-q" for="ff-20">Nombre de clients payants <span id="ff-20-req-label"></span></label>
        <input type="number" id="ff-20" class="ff-input" min="0" placeholder="0" />
        <div class="ff-error" id="ff-err-20" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="20">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="20">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="21" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <label class="ff-q" for="ff-21">Pourquoi VOUS ?</label>
        <div class="ff-field-wrap">
          <textarea id="ff-21" class="ff-textarea" maxlength="500" rows="5" aria-required="true" placeholder="Présentez l'équipe fondatrice et votre avantage compétitif…"></textarea>
          <span class="ff-counter" id="ff-count-21">0 / 500</span>
        </div>
        <div class="ff-error" id="ff-err-21" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="21">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="21">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="22" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <p class="ff-q">L'équipe est-elle à temps plein ?</p>
        <div class="ff-choices ff-choices--duo" id="ff-22" role="group" aria-label="Temps plein">
          <button type="button" class="ff-choice" data-value="Oui">Oui</button>
          <button type="button" class="ff-choice" data-value="Non">Non</button>
        </div>
        <div class="ff-error" id="ff-err-22" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="22">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="22">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="23" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">Exécution &amp; Équipe</p>
        <label class="ff-q" for="ff-23">Priorité des 6 prochains mois</label>
        <textarea id="ff-23" class="ff-textarea" rows="5" aria-required="true" placeholder="Votre objectif numéro un…"></textarea>
        <div class="ff-error" id="ff-err-23" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="23">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="23">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="24" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">La Demande</p>
        <p class="ff-q">Combien souhaitez-vous lever ?</p>
        <div class="ff-choices" id="ff-24" role="group" aria-label="Montant levée">
          <button type="button" class="ff-choice" data-value="< 100k€">&lt;&nbsp;100k€</button>
          <button type="button" class="ff-choice" data-value="100k–500k€">100k – 500k€</button>
          <button type="button" class="ff-choice" data-value="500k–1M€">500k – 1M€</button>
          <button type="button" class="ff-choice" data-value="1M–3M€">1M – 3M€</button>
          <button type="button" class="ff-choice" data-value="> 3M€">&gt;&nbsp;3M€</button>
        </div>
        <div class="ff-error" id="ff-err-24" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="24">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="24">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="25" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">La Demande</p>
        <label class="ff-q" for="ff-25">Jalons clés — 18 prochains mois</label>
        <textarea id="ff-25" class="ff-textarea" rows="5" aria-required="true" placeholder="Milestones produit, revenus, équipe…"></textarea>
        <div class="ff-error" id="ff-err-25" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="25">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="25">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="26" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">La Demande</p>
        <label class="ff-q" for="ff-26">Utilisation prévue des fonds <span class="ff-opt">— optionnel</span></label>
        <textarea id="ff-26" class="ff-textarea" rows="5" placeholder="R&D, recrutement, marketing…"></textarea>
        <div class="ff-error" id="ff-err-26" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="26">← Retour</button></div>
          <div class="ff-nav-right"><button class="ff-btn-next ff-btn-primary" data-step="26">Continuer</button></div>
        </nav>
      </div>
    </div>

    <div class="ff-step" data-step="27" hidden>
      <div class="ff-step-inner">
        <p class="ff-eyebrow">La Demande</p>
        <label class="ff-q" for="ff-27">À quoi ressemble votre entreprise dans 5 ans ?</label>
        <textarea id="ff-27" class="ff-textarea" rows="5" aria-required="true" placeholder="Votre vision long terme…"></textarea>
        <div class="ff-error" id="ff-err-27" role="alert"></div>
        <nav class="ff-nav">
          <div class="ff-nav-left"><button class="ff-btn-back" data-step="27">← Retour</button></div>
