  transition:color .2s;
  letter-spacing:.06em;
  text-transform:uppercase;
}
.ff-btn-back:hover{color:var(--text-muted)}

/* ─── Keyboard hint ───────────────────────────────────────── */
.ff-kbd-bar{
  font-size:.72rem;
  color:var(--text-dim);
  display:none; /* Affiché via JS */
  align-items:center;
  gap:8px;
  pointer-events:none;
  white-space:nowrap;
  opacity:0;
  transition:opacity .3s;
  letter-spacing:.08em;
  text-transform:uppercase;
