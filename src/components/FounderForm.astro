  DK:['Copenhague','Aarhus','Odense','Aalborg','Frederiksberg','Esbjerg'],
  FI:['Helsinki','Espoo','Tampere','Vantaa','Oulu','Turku','Jyväskylä','Lahti'],
  PL:['Varsovie','Cracovie','Łódź','Wrocław','Poznań','Gdańsk','Szczecin'],
