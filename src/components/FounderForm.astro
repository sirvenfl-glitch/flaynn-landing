<style>
/* ─── Reset + variables locales ──────────────────────────── */
#ff-overlay *,#ff-overlay *::before,#ff-overlay *::after{box-sizing:border-box;margin:0;padding:0}
#ff-overlay{
  --ok:#4ade80;
  --err:#f87171;
  --gold:#C9A84C;
  --purple-light:#9333ea;
  --pink:#EC4899;
  --purple:#6B21A8;
  --orange:#F97316;
  --text:#F1F5F9;
  --text-muted:#94a3b8;
  --text-dim:#475569;
  --bg:#0A0A0F;
  --font:'IBM Plex Sans',sans-serif;
  position:fixed;inset:0;z-index:9000;
  width:100%;height:100%;box-sizing:border-box;
  background:
    radial-gradient(ellipse at 30% 40%, rgba(107,33,168,.12), transparent 60%),
    var(--bg);
  font-family:var(--font);
  color:var(--text);
  display:flex;flex-direction:column;
  overflow-y:auto;
}
#ff-overlay[hidden]{display:none}

/* ─── Header ──────────────────────────────────────────────── */
.ff-header{
  position:fixed;top:0;left:0;right:0;z-index:9001;
}
.ff-progress-track{
  height:3px;
  background:rgba(255,255,255,.05);
  position:relative;
}
.ff-bar{
  height:100%;
  background:linear-gradient(90deg,var(--purple-light),var(--pink));
  width:0%;
  transition:width .3s ease-out;
}
.ff-header-meta{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:20px 60px;
  min-height:48px;
}
.ff-brand{
  font-size:.7rem;
  font-weight:700;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--text-dim);
}
.ff-step-label{
  font-size:.68rem;
  font-weight:600;
  color:var(--gold);
  letter-spacing:.08em;
  font-variant-numeric:tabular-nums;
}

/* ─── Main / Steps ────────────────────────────────────────── */
.ff-main{
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:120px 48px 100px;
  width:100%;
}

.ff-step{
  position:relative;
  width:100%;
  max-width:560px;
  margin:0 auto;
  animation:ff-in .3s ease-out both;
}
.ff-step[hidden]{display:none!important}
.ff-step.leaving{
  animation:ff-out .22s ease-in both;
  pointer-events:none;
}

.ff-step::before{
  content:attr(data-step);
  position:absolute;
  top:-60px;
  left:-16px;
  font-size:10rem;
  font-weight:700;
  line-height:1;
  color:var(--purple-light);
  opacity:.13;
  pointer-events:none;
  user-select:none;
  z-index:0;
  font-variant-numeric:tabular-nums;
  letter-spacing:-.05em;
}

.ff-step-inner{
  position:relative;
  z-index:1;
}

@keyframes ff-in{
  from{opacity:0;transform:translateY(40px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes ff-out{
  from{opacity:1;transform:translateY(0)}
  to{opacity:0;transform:translateY(-24px)}
}

/* ─── Typographie ─────────────────────────────────────────── */
.ff-eyebrow{
  font-size:.7rem;
  font-weight:600;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--purple-light);
  margin-bottom:24px;
}
.ff-q{
  display:block;
  font-size:clamp(2.8rem,5vw,4.2rem);
