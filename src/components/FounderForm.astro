  ['Nouvelle-Zélande','NZ'],['Oman','OM'],['Ouganda','UG'],['Ouzbékistan','UZ'],
  ['Pakistan','PK'],['Palaos','PW'],['Palestine','PS'],['Panama','PA'],
  ['Papouasie-Nouvelle-Guinée','PG'],['Paraguay','PY'],['Pays-Bas','NL'],['Pérou','PE'],
